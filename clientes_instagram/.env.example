# Auth — una de estas dos opciones
IG_SESSION_ID=your_sessionid_from_browser_cookies

# Alternativa usuario/password (puede fallar desde EC2/datacenter IPs)
# IG_USERNAME=tu_usuario
# IG_PASSWORD=tu_password

# Configuracion de extraccion
IG_TARGET=clinicavesaliooficial
IG_AMOUNT=20

# Firecrawl (para --enrich)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxx

# Proxy residencial (opcional, reduce rate limits)
# PROXY_URL=http://user:pass@host:port
